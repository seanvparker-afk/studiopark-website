---
import BaseLayout from '../layouts/BaseLayout.astro';
import calgary from '../data/calgary-downtown.json';

// Studio location map — projects real OSM downtown Calgary geometry through
// a plain equirectangular projection at neighborhood scale.
const VBW = 1000;
const VBH = 600;
const BBOX = { west: -114.100, east: -114.020, south: 51.030, north: 51.060 };

function project(lon: number, lat: number): [number, number] {
  return [
    ((lon - BBOX.west) / (BBOX.east - BBOX.west)) * VBW,
    ((BBOX.north - lat) / (BBOX.north - BBOX.south)) * VBH,
  ];
}

function toPath(geom: [number, number][], close = false): string {
  const pts = geom.map(([lon, lat]) => project(lon, lat));
  return 'M' + pts.map((p) => p[0].toFixed(1) + ',' + p[1].toFixed(1)).join('L') + (close ? 'Z' : '');
}

type Feature = { tier: string; geom: [number, number][]; id: number; name?: string; label?: string };
const features = (calgary.features as Feature[]).map((f) => ({
  ...f,
  d: toPath(f.geom, f.tier === 'stampede_park' || f.tier === 'princes_island'),
}));

const byTier = (tier: string) => features.filter((f) => f.tier === tier);

// One labeled <textPath> per major street name — pick the longest segment.
const labelMap = new Map<string, Feature & { d: string }>();
for (const f of features) {
  if (!f.label) continue;
  const cur = labelMap.get(f.label);
  if (!cur || f.geom.length > cur.geom.length) labelMap.set(f.label, f);
}
const labelStreets = [...labelMap.entries()].map(([label, f]) => ({
  label,
  d: f.d,
  pathId: 'street-' + label.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  isStudio: label === '10 AVE SW',
}));

// Studio HQ: 1933 10 Ave SW, Calgary
const STUDIO_LL: [number, number] = [-114.0820, 51.0447];
const [studioX, studioY] = project(STUDIO_LL[0], STUDIO_LL[1]);

// Hand-positioned neighborhood labels — context, not from OSM.
const NEIGHBORHOODS = [
  { label: 'EAU CLAIRE', lon: -114.067, lat: 51.0535 },
  { label: 'DOWNTOWN', lon: -114.067, lat: 51.0475 },
  { label: 'EAST VILLAGE', lon: -114.045, lat: 51.0455 },
  { label: 'BELTLINE', lon: -114.075, lat: 51.0405 },
  { label: 'INGLEWOOD', lon: -114.030, lat: 51.0395 },
].map((n) => {
  const [x, y] = project(n.lon, n.lat);
  return { label: n.label, x, y };
});
