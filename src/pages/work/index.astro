---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);

// Positional layout tuned for the homepage "Selected Work" rhythm.
// With 6 items we paint a 7/5, 4/4/4, then full-width panoramic cadence.
// Any extras after position 5 fall through to a uniform 4-col grid.
type Layout = { span: string; aspect: string };
const layoutFor = (i: number): Layout => {
  switch (i) {
    case 0: return { span: 'md:col-span-7', aspect: 'aspect-[16/11]' };
    case 1: return { span: 'md:col-span-5', aspect: 'aspect-[4/5] md:aspect-auto' };
    case 2:
    case 3:
    case 4: return { span: 'md:col-span-4', aspect: 'aspect-[4/5]' };
    case 5: return { span: 'md:col-span-12', aspect: 'aspect-[16/10] md:aspect-[21/9]' };
    default: return { span: 'md:col-span-4', aspect: 'aspect-[4/5]' };
  }
};
---

<BaseLayout
  title="Work — Studio Park"
  description="Selected activations and productions from Studio Park across Western Canada."
>
  <!-- ===================== NAV ===================== -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-10 py-4 flex items-center justify-between"
       style="background: linear-gradient(to bottom, rgba(19,17,16,0.92), rgba(19,17,16,0)); backdrop-filter: blur(10px);">
    <a href="/" class="flex items-center gap-3">
      <img src="/studiopark-logo.png" alt="Studio Park" class="logo-mark h-8 md:h-9 w-auto" />
    </a>
    <ul class="hidden md:flex items-center gap-8 text-[13px]" style="color: var(--cream);">
      <li><a href="/work" class="nav-link active">Work</a></li>
      <li><a href="/content" class="nav-link">Content</a></li>
      <li><a href="/staffing" class="nav-link">Staffing</a></li>
      <li><a href="/consulting" class="nav-link">Consulting</a></li>
      <li><a href="/contact" class="nav-link">Contact</a></li>
    </ul>
    <div class="hidden md:flex items-center gap-3 text-xs mono" style="color: var(--cream-dim);">
      <span class="w-1.5 h-1.5 rounded-full blink" style="background: var(--accent);"></span>
      YYC · Open for Q2 '26
    </div>
  </nav>

  <!-- ===================== HERO ===================== -->
  <section class="relative px-6 md:px-10 pt-32 md:pt-40 pb-14 md:pb-20">
    <div class="flex items-start justify-between mb-14 md:mb-20">
      <div class="rise" style="animation-delay: 0.1s;">
        <div class="label mb-2">§ — Selected Work</div>
        <div class="label" style="color: var(--cream);">2024 / Vol. IX</div>
      </div>
      <div class="text-right rise" style="animation-delay: 0.2s;">
        <div class="label mb-2">{entries.length.toString().padStart(2, '0')} Case Studies</div>
        <div class="label" style="color: var(--cream);">Western Canada</div>
      </div>
    </div>

    <h1 class="display text-[14vw] md:text-[10vw] rise" style="animation-delay: 0.3s;">
      Recent activations<span class="dot-accent">.</span>
    </h1>

    <div class="grid grid-cols-12 gap-6 mt-10 md:mt-14">
      <div class="col-span-12 md:col-span-5">
        <p class="text-[15px] md:text-base leading-relaxed rise" style="color: var(--cream-dim); animation-delay: 0.6s;">
          Festivals, daytime takeovers, and brand moments from Calgary to Vancouver. Each one staffed, captured, and produced by the same western team — the people who actually show up.
        </p>
      </div>
      <div class="col-span-12 md:col-span-7 flex md:justify-end items-end">
        <div class="mono text-xs flex items-center gap-3" style="color: var(--cream-dim);">
          <span class="h-px w-10" style="background: var(--line);"></span>
          Sorted by recency — newest activations first.
        </div>
      </div>
    </div>

    <div class="h-px widen mt-14 md:mt-20" style="background: var(--line); animation-delay: 0.9s;"></div>
  </section>

  <!-- ===================== PORTFOLIO GRID ===================== -->
  <section class="px-6 md:px-10 pb-24 md:pb-36">
    <div class="grid grid-cols-12 gap-4 md:gap-5">
      {entries.map((entry, i) => {
        const { span, aspect } = layoutFor(i);
        const img = entry.data.thumbImage ?? entry.data.heroImage;
        return (
          <a
            href={`/work/${entry.id}`}
            class={`col-span-12 ${span} group relative img-wrap ${aspect} block`}
          >
            <img src={img} alt={entry.data.heroAlt} />
            <figcaption class="caption absolute bottom-0 left-0 right-0 p-5 md:p-6 flex items-end justify-between gap-4">
              <div>
                <div class="label mb-1">Case / {entry.data.caseNumber}</div>
                <div class="display-md text-lg md:text-xl">{entry.data.title}</div>
                <div class="label mt-2" style="color: var(--cream-dim);">
                  {entry.data.locations.join(' · ')}
                </div>
              </div>
              <div class="mono text-xs hidden md:block" style="color: var(--cream-dim);">
                {entry.data.year}
              </div>
            </figcaption>
          </a>
        );
      })}
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="px-6 md:px-10 py-28 md:py-40 relative overflow-hidden border-t" style="border-color: var(--line);">
    <div class="glow absolute inset-0"></div>
    <div class="relative">
      <div class="label mb-6" style="color: var(--accent);">§ — Start a Project</div>
      <h2 class="display text-[13vw] md:text-[10vw]">
        Your brief,<br/>our grounds<span class="dot-accent">.</span>
      </h2>
      <p class="mt-10 max-w-xl text-[15px] leading-relaxed" style="color: var(--cream-dim);">
        Planning an activation in Calgary, Edmonton, Vancouver, or anywhere in between? Send the brief — we'll reply within a business day with scope, dates, and a local crew.
      </p>
      <div class="mt-12 flex flex-col md:flex-row items-start md:items-center gap-6">
        <a href="/contact" class="btn inline-flex items-center gap-3 text-lg display-md px-8 py-4 border" style="border-color: var(--cream); color: var(--cream);">
          Send us the brief
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
        <span class="label">or email hello@studiopark.ca</span>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="px-6 md:px-10 pt-20 pb-10 border-t" style="border-color: var(--line);">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 md:col-span-5">
        <img src="/studiopark-logo.png" alt="Studio Park" class="logo-mark h-9 w-auto mb-6" />
        <p class="text-[14px] max-w-xs leading-relaxed" style="color: var(--cream-dim);">
          Western Canada's premier experiential production partner. Calgary-based, nationally trusted.
        </p>
      </div>
      <div class="col-span-6 md:col-span-2">
        <div class="label mb-5">Services</div>
        <ul class="space-y-3 text-sm">
          <li><a href="/work" class="nav-link">Work</a></li>
          <li><a href="/content" class="nav-link">Content</a></li>
          <li><a href="/staffing" class="nav-link">Staffing</a></li>
          <li><a href="/consulting" class="nav-link">Consulting</a></li>
        </ul>
      </div>
      <div class="col-span-6 md:col-span-2">
        <div class="label mb-5">Connect</div>
        <ul class="space-y-3 text-sm">
          <li><a href="/contact" class="nav-link">Contact</a></li>
          <li><a href="mailto:hello@studiopark.ca" class="nav-link">Email</a></li>
          <li><a href="#" class="nav-link">Instagram</a></li>
        </ul>
      </div>
      <div class="col-span-12 md:col-span-3">
        <div class="label mb-5">Visit</div>
        <p class="text-[14px] leading-relaxed" style="color: var(--cream-dim);">
          1933 10 Ave SW, #301<br/>Calgary, AB T3C 0K3<br/>Canada
        </p>
      </div>
    </div>
    <div class="h-px mb-8" style="background: var(--line);"></div>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs mono" style="color: var(--cream-dim);">
      <div>© 2026 Studio Park Experiential Inc. All rights reserved.</div>
      <div class="flex items-center gap-5 flex-wrap">
        <span>51.0447° N · 114.0719° W</span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full blink" style="background: var(--accent);"></span>
          Open for Q2 '26 bookings
        </span>
      </div>
    </div>
  </footer>
</BaseLayout>
