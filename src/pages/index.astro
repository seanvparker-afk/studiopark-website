---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Studio Park — Western Canada's experiential production partner">

  <!-- ===================== NAV ===================== -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-10 py-4 flex items-center justify-between"
       style="background: linear-gradient(to bottom, rgba(19,17,16,0.92), rgba(19,17,16,0)); backdrop-filter: blur(10px);">
    <a href="#" class="flex items-center gap-3">
      <img src="/studiopark-logo.png" alt="Studio Park" class="logo-mark h-8 md:h-9 w-auto" />
    </a>
    <ul class="hidden md:flex items-center gap-8 text-[13px]" style="color: var(--cream);">
      <li><a href="/content" class="nav-link">Content</a></li>
      <li><a href="/staffing" class="nav-link">Staffing</a></li>
      <li><a href="/consulting" class="nav-link">Consulting</a></li>
      <li><a href="/contact" class="nav-link">Contact</a></li>
    </ul>
    <div class="hidden md:flex items-center gap-3 text-xs mono" style="color: var(--cream-dim);">
      <span class="w-1.5 h-1.5 rounded-full blink" style="background: var(--accent);"></span>
      YYC · Open for Q2 '26
    </div>
  </nav>

  <!-- ===================== HERO ===================== -->
  <section class="relative px-6 md:px-10 pt-32 md:pt-40 pb-10 overflow-hidden">
    <!-- Top meta strip -->
    <div class="flex items-start justify-between mb-14 md:mb-24">
      <div class="rise" style="animation-delay: 0.1s;">
        <div class="label mb-2">(01) — Experiential Production</div>
        <div class="label" style="color: var(--cream);">Calgary, Alberta</div>
      </div>
      <div class="text-right rise" style="animation-delay: 0.2s;">
        <div class="label mb-2">Vol. IX / 2026</div>
        <div class="label" style="color: var(--cream);">Est. 2019</div>
      </div>
    </div>

    <!-- Display headline -->
    <h1 class="display text-[16vw] md:text-[11.5vw] rise" style="animation-delay: 0.3s;">
      Your western
    </h1>
    <div class="flex items-end justify-between gap-8 mt-2 md:mt-4">
      <h1 class="display text-[16vw] md:text-[11.5vw] rise" style="animation-delay: 0.5s;">
        branch<span class="dot-accent">.</span>
      </h1>
      <p class="hidden md:block max-w-sm text-[15px] leading-relaxed pb-5 rise" style="color: var(--cream-dim); animation-delay: 0.7s;">
        National agencies lose control the moment a campaign leaves head office. We're the boots-on-the-ground partner the brief was missing — content, staffing, and local logistics under one Calgary banner.
      </p>
    </div>

    <!-- Mobile description -->
    <p class="md:hidden mt-6 text-[15px] leading-relaxed" style="color: var(--cream-dim);">
      National agencies lose control the moment a campaign leaves head office. We're the boots-on-the-ground partner the brief was missing — content, staffing, and local logistics under one Calgary banner.
    </p>

    <!-- Divider -->
    <div class="h-px widen mt-14 md:mt-20" style="background: var(--line); animation-delay: 0.9s;"></div>

    <!-- Hero image row -->
    <div class="grid grid-cols-12 gap-4 md:gap-5 mt-10 md:mt-12 rise" style="animation-delay: 1.1s;">
      <div class="col-span-12 md:col-span-8 img-wrap aspect-[16/10] md:aspect-[16/9]">
        <img
          src="https://static.wixstatic.com/media/506540_f339de76671e4dd3b9183c26d007cc0d~mv2.jpg/v1/fit/w_1600,h_1067,q_90,enc_avif,quality_auto/506540_f339de76671e4dd3b9183c26d007cc0d~mv2.jpg"
          alt="Studio Park activation — Calgary"
        />
        <div class="caption absolute bottom-0 left-0 right-0 p-5 md:p-7 flex items-end justify-between">
          <div>
            <div class="label mb-1">Case / 008</div>
            <div class="display-md text-lg md:text-xl">Nashville North — Calgary Stampede</div>
          </div>
          <div class="label hidden md:block">Content · Staffing</div>
        </div>
      </div>
      <div class="col-span-12 md:col-span-4 flex flex-col justify-between gap-4 md:gap-5">
        <div class="img-wrap aspect-[4/5] flex-1">
          <img
            src="https://static.wixstatic.com/media/506540_af9f6f7bfa9e49feaad0324b5643d6bf~mv2.jpg/v1/fit/w_800,h_1000,q_90,enc_avif,quality_auto/file.jpg"
            alt="Event talent"
          />
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 nudge">
            <div class="label">Scroll</div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A69E91" stroke-width="1.5">
              <path d="M12 5v14M5 12l7 7 7-7"/>
            </svg>
          </div>
          <div class="mono text-xs" style="color: var(--cream-dim);">002 / 014</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MARQUEE ===================== -->
  <section class="py-10 md:py-14 border-y overflow-hidden" style="border-color: var(--line);">
    <div class="flex marquee-track whitespace-nowrap">
      <div class="flex items-center gap-10 md:gap-14 pr-10 md:pr-14">
        <span class="display-md text-4xl md:text-6xl">Content Production</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--accent);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Talent &amp; Staffing</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--magenta);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Consulting</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--accent);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Local Logistics</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--magenta);">✺</span>
      </div>
      <div class="flex items-center gap-10 md:gap-14 pr-10 md:pr-14" aria-hidden="true">
        <span class="display-md text-4xl md:text-6xl">Content Production</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--accent);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Talent &amp; Staffing</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--magenta);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Consulting</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--accent);">✺</span>
        <span class="display-md text-4xl md:text-6xl">Local Logistics</span>
        <span class="text-4xl md:text-6xl spin-slow" style="color: var(--magenta);">✺</span>
      </div>
    </div>
  </section>

  <!-- ===================== REEL VIDEO SECTION ===================== -->
  <section id="reel" class="relative overflow-hidden">
    <div class="relative aspect-[16/10] md:aspect-[21/9] group cursor-pointer">
      <!-- Video placeholder image -->
      <img
        src="https://static.wixstatic.com/media/506540_9435882fc07f409b944dff376764c76d~mv2.jpg/v1/fit/w_2000,h_1200,q_90,enc_avif,quality_auto/file.jpg"
        alt="Studio Park 2025 Reel"
        class="absolute inset-0 w-full h-full object-cover"
        style="filter: saturate(0.8) brightness(0.75);"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(19,17,16,0.4) 0%, rgba(19,17,16,0.25) 40%, rgba(19,17,16,0.7) 100%);"></div>

      <!-- Top corner labels -->
      <div class="absolute top-6 md:top-8 left-6 md:left-10 right-6 md:right-10 flex items-start justify-between">
        <div class="label" style="color: var(--cream);">§ 02 — Reel / 2025</div>
        <div class="mono text-xs" style="color: var(--cream);">REC · 01:47</div>
      </div>

      <!-- Center play button -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative flex items-center justify-center">
          <span class="absolute inset-0 rounded-full pulse-ring" style="background: rgba(213, 68, 32, 0.3); width: 130px; height: 130px;"></span>
          <span class="absolute inset-0 rounded-full pulse-ring" style="background: rgba(213, 68, 32, 0.2); width: 130px; height: 130px; animation-delay: 1.2s;"></span>
          <button
            class="relative w-24 h-24 md:w-32 md:h-32 rounded-full flex items-center justify-center transition-transform duration-500 group-hover:scale-110"
            style="background: var(--accent); box-shadow: 0 20px 60px rgba(213,68,32,0.35);"
            aria-label="Play reel"
          >
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#F2EDE3" style="margin-left: 4px;">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Bottom copy -->
      <div class="absolute bottom-6 md:bottom-10 left-6 md:left-10 right-6 md:right-10 flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="display text-4xl md:text-6xl mb-2">A year, in motion.</h2>
          <p class="text-sm md:text-base max-w-md" style="color: var(--cream-dim);">
            Fifteen activations. Four provinces. Selected moments from 2024 — captured, staffed, and produced by us.
          </p>
        </div>
        <div class="label" style="color: var(--cream);">Watch reel →</div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section id="services" class="px-6 md:px-10 py-24 md:py-36">
    <div class="grid grid-cols-12 gap-6 mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-4">
        <div class="label mb-4">§ 03 — Capabilities</div>
      </div>
      <div class="col-span-12 md:col-span-8">
        <h2 class="display-md text-4xl md:text-6xl">
          Three integrated services.<br/>
          <span style="color: var(--cream-dim);">One western branch.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-5">

      <article class="group">
        <div class="img-wrap aspect-[4/5] mb-6">
          <img
            src="https://static.wixstatic.com/media/506540_f6e16f054d944fc89c561bd789c3749c~mv2.jpg/v1/fit/w_900,h_1125,q_90,enc_avif,quality_auto/file.jpg"
            alt="Content production"
          />
        </div>
        <div class="flex items-baseline justify-between mb-4">
          <span class="idx text-4xl">01</span>
          <span class="label">Capture</span>
        </div>
        <h3 class="display-md text-2xl md:text-3xl mb-3">Content Production</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Same-day edits. Case-study stills. Broadcast-quality capture that respects your client's brand guidelines and the pace of a live activation.
        </p>
        <a href="/content" class="inline-flex items-center gap-2 mt-6 text-sm nav-link">
          Explore content <span>→</span>
        </a>
      </article>

      <article class="group md:mt-16">
        <div class="img-wrap aspect-[4/5] mb-6">
          <img
            src="https://static.wixstatic.com/media/506540_8f409386c79241a09b85b753d035c24e~mv2.jpg/v1/fit/w_900,h_1125,q_90,enc_avif,quality_auto/file.jpg"
            alt="Talent and staffing"
          />
        </div>
        <div class="flex items-baseline justify-between mb-4">
          <span class="idx text-4xl" style="color: var(--magenta);">02</span>
          <span class="label">Represent</span>
        </div>
        <h3 class="display-md text-2xl md:text-3xl mb-3">Talent &amp; Staffing</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Trained, not just staffed. Vetted brand ambassadors across Western Canada — payroll, training, and uniforms handled on our side of the ledger.
        </p>
        <a href="/staffing" class="inline-flex items-center gap-2 mt-6 text-sm nav-link">
          Meet the roster <span>→</span>
        </a>
      </article>

      <article class="group md:mt-8">
        <div class="img-wrap aspect-[4/5] mb-6">
          <img
            src="https://static.wixstatic.com/media/81231b_f938854487ab41fba46ca7431ee726e2~mv2.jpg/v1/fit/w_900,h_1125,q_90,enc_avif,quality_auto/file.jpg"
            alt="Consulting and logistics"
          />
        </div>
        <div class="flex items-baseline justify-between mb-4">
          <span class="idx text-4xl">03</span>
          <span class="label">Navigate</span>
        </div>
        <h3 class="display-md text-2xl md:text-3xl mb-3">Consulting &amp; Logistics</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Permits, venue scouting, municipal liaison, run-of-show. We know the by-laws, the venues, and the culture so your load-in never turns into a lesson.
        </p>
        <a href="/consulting" class="inline-flex items-center gap-2 mt-6 text-sm nav-link">
          See the playbook <span>→</span>
        </a>
      </article>
    </div>
  </section>

  <!-- ===================== PULL QUOTE ===================== -->
  <section class="px-6 md:px-10 py-24 md:py-32 border-y" style="border-color: var(--line); background: var(--bg-lift);">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-3 mb-10">
        <span class="dot-accent text-2xl">❝</span>
        <span class="label">Client testimony</span>
      </div>
      <p class="pullquote text-3xl md:text-5xl">
        "It was amazing working with the Studio Park team. I'd recommend them to elevate any activation."
      </p>
      <div class="mt-12 flex items-baseline gap-6">
        <span class="h-px flex-shrink-0 w-12" style="background: var(--accent);"></span>
        <div>
          <div class="display-md text-lg">Kayla-Rae Maurer</div>
          <div class="label mt-1">Agency Partner</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section id="process" class="px-6 md:px-10 py-24 md:py-36">
    <div class="grid grid-cols-12 gap-6 mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-4">
        <div class="label mb-4">§ 04 — How We Work</div>
      </div>
      <div class="col-span-12 md:col-span-8">
        <h2 class="display-md text-4xl md:text-6xl">
          From brief to load-out,<br/>
          <span style="color: var(--cream-dim);">without surprises.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t" style="border-color: var(--line);">
      <div class="p-6 md:p-10 md:border-r" style="border-color: var(--line);">
        <div class="flex items-center gap-4 mb-6">
          <span class="idx text-5xl">01</span>
          <span class="h-px flex-1 grow-line" style="background: var(--accent);"></span>
        </div>
        <h3 class="display-md text-xl md:text-2xl mb-4">Inquiry &amp; Alignment</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Objectives, markets, timelines, on-site requirements. We align before the clock starts so nothing slips between strategy and execution.
        </p>
      </div>
      <div class="p-6 md:p-10 md:border-r" style="border-color: var(--line);">
        <div class="flex items-center gap-4 mb-6">
          <span class="idx text-5xl">02</span>
          <span class="h-px flex-1 grow-line" style="background: var(--accent); animation-delay: 0.6s;"></span>
        </div>
        <h3 class="display-md text-xl md:text-2xl mb-4">Planning &amp; Coordination</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Staffing, permitting, venues, run-of-show, content needs. Your local producers anticipating what the deck didn't cover.
        </p>
      </div>
      <div class="p-6 md:p-10">
        <div class="flex items-center gap-4 mb-6">
          <span class="idx text-5xl">03</span>
          <span class="h-px flex-1 grow-line" style="background: var(--accent); animation-delay: 0.9s;"></span>
        </div>
        <h3 class="display-md text-xl md:text-2xl mb-4">On-Site Execution</h3>
        <p class="text-[15px] leading-relaxed" style="color: var(--cream-dim);">
          Load-in to load-out. Talent, guest flow, brand standards, content capture, live troubleshooting. Your brief, delivered with pride.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== WORK / PORTFOLIO ===================== -->
  <section id="work" class="px-6 md:px-10 py-24 md:py-36">
    <div class="flex items-end justify-between mb-14 md:mb-20 flex-wrap gap-6">
      <div>
        <div class="label mb-4">§ 05 — Selected Work</div>
        <h2 class="display-md text-4xl md:text-6xl">
          Recent activations.
        </h2>
      </div>
      <a href="#" class="btn inline-flex items-center gap-2 text-sm border px-6 py-3" style="border-color: var(--cream); color: var(--cream);">
        View all work <span>→</span>
      </a>
    </div>

    <!-- Row 1: 7/5 -->
    <div class="grid grid-cols-12 gap-4 md:gap-5 mb-4 md:mb-5">
      <figure class="col-span-12 md:col-span-7 img-wrap aspect-[16/11]">
        <img
          src="https://static.wixstatic.com/media/506540_9435882fc07f409b944dff376764c76d~mv2.jpg/v1/fit/w_1400,h_960,q_90,enc_avif,quality_auto/file.jpg"
          alt="Cowboys Tent Festival Activation"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-5 flex items-end justify-between">
          <div>
            <div class="label mb-1">Case / 012</div>
            <div class="display-md text-lg">Cowboys Tent — Festival Activation</div>
          </div>
          <div class="mono text-xs" style="color: var(--cream-dim);">2024</div>
        </figcaption>
      </figure>
      <figure class="col-span-12 md:col-span-5 img-wrap aspect-[4/5] md:aspect-auto">
        <img
          src="https://static.wixstatic.com/media/81231b_881d6ead66844407be897c40020f253a~mv2.jpg/v1/fit/w_900,h_1200,q_90,enc_avif,quality_auto/file.jpg"
          alt="Talent portrait"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-5 flex items-end justify-between">
          <div>
            <div class="label mb-1">Case / 011</div>
            <div class="display-md text-lg">On-Site Talent Direction</div>
          </div>
        </figcaption>
      </figure>
    </div>

    <!-- Row 2: 4/4/4 -->
    <div class="grid grid-cols-12 gap-4 md:gap-5 mb-4 md:mb-5">
      <figure class="col-span-12 md:col-span-4 img-wrap aspect-[4/5]">
        <img
          src="https://static.wixstatic.com/media/506540_534ae00c1b6648c89122601963445564~mv2.jpg/v1/fit/w_800,h_1000,q_90,enc_avif,quality_auto/file.jpg"
          alt="Event detail"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-4">
          <div class="label">Brand integration</div>
        </figcaption>
      </figure>
      <figure class="col-span-12 md:col-span-4 img-wrap aspect-[4/5]">
        <img
          src="https://static.wixstatic.com/media/81231b_4d6aec1924194d60bac83b753d944cf3~mv2.jpg/v1/fit/w_800,h_1000,q_90,enc_avif,quality_auto/file.jpg"
          alt="Event detail"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-4">
          <div class="label">On-site capture</div>
        </figcaption>
      </figure>
      <figure class="col-span-12 md:col-span-4 img-wrap aspect-[4/5]">
        <img
          src="https://static.wixstatic.com/media/506540_f339de76671e4dd3b9183c26d007cc0d~mv2.jpg/v1/fit/w_800,h_1000,q_90,enc_avif,quality_auto/file.jpg"
          alt="Event detail"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-4">
          <div class="label">Activation staffing</div>
        </figcaption>
      </figure>
    </div>

    <!-- Row 3: 5/7 reversed -->
    <div class="grid grid-cols-12 gap-4 md:gap-5">
      <figure class="col-span-12 md:col-span-5 img-wrap aspect-[4/5] md:aspect-auto">
        <img
          src="https://static.wixstatic.com/media/81231b_f938854487ab41fba46ca7431ee726e2~mv2.jpg/v1/fit/w_900,h_1200,q_90,enc_avif,quality_auto/file.jpg"
          alt="Consulting"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-5 flex items-end justify-between">
          <div>
            <div class="label mb-1">Case / 009</div>
            <div class="display-md text-lg">Venue &amp; Permit Coordination</div>
          </div>
        </figcaption>
      </figure>
      <figure class="col-span-12 md:col-span-7 img-wrap aspect-[16/11]">
        <img
          src="https://static.wixstatic.com/media/506540_8f409386c79241a09b85b753d035c24e~mv2.jpg/v1/fit/w_1400,h_960,q_90,enc_avif,quality_auto/file.jpg"
          alt="Event activation"
        />
        <figcaption class="caption absolute bottom-0 left-0 right-0 p-5 flex items-end justify-between">
          <div>
            <div class="label mb-1">Case / 010</div>
            <div class="display-md text-lg">Brand Ambassador Program — Multi-City</div>
          </div>
          <div class="mono text-xs" style="color: var(--cream-dim);">2024</div>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ===================== CLIENTS ===================== -->
  <section class="px-6 md:px-10 py-20 border-t" style="border-color: var(--line);">
    <div class="grid grid-cols-12 gap-6 items-center">
      <div class="col-span-12 md:col-span-3">
        <div class="label mb-3">§ 06 — Trusted By</div>
        <p class="text-[14px]" style="color: var(--cream-dim);">
          Agencies and brands activating across Western Canada.
        </p>
      </div>
      <div class="col-span-12 md:col-span-9 grid grid-cols-2 md:grid-cols-4 gap-8 items-center">
        <div class="display-md text-xl md:text-2xl" style="color: var(--cream-dim);">Mosaic</div>
        <div class="display-md text-xl md:text-2xl" style="color: var(--cream-dim);">ABF</div>
        <div class="display-md text-xl md:text-2xl" style="color: var(--cream-dim);">Match MG</div>
        <div class="display-md text-xl md:text-2xl" style="color: var(--cream-dim);">Stampede Co.</div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section id="contact" class="px-6 md:px-10 py-28 md:py-44 relative overflow-hidden">
    <div class="glow absolute inset-0"></div>
    <div class="relative">
      <div class="label mb-6" style="color: var(--accent);">§ 07 — Start a Project</div>
